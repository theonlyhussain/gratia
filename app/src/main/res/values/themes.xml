<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Gratia" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/gr_base_dark</item>
    </style>

    <style name="Theme.Gratia.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/gr_base_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Gratia</item>
    </style>
</resources>
